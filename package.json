{
  "name": "@firfi/obs-mcp",
  "version": "0.3.2",
  "description": "MCP server for OBS Studio websocket automation and read-only resources",
  "mcpName": "io.github.dearlordylord/obs-mcp",
  "type": "module",
  "main": "./dist/index.cjs",
  "files": [
    "dist/index.cjs",
    "server.json",
    "README.md",
    "INTEGRATION_TESTING.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dearlordylord/obs-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/dearlordylord/obs-mcp/issues"
  },
  "homepage": "https://github.com/dearlordylord/obs-mcp",
  "scripts": {
    "prepare": "husky",
    "start": "node dist/index.cjs",
    "build": "PKG_VERSION=$(node -p \"require('./package.json').version\") && esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --external:ws \"--define:PKG_VERSION=\\\"$PKG_VERSION\\\"\"",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "test": "vitest run",
    "test:integration": "OBS_INTEGRATION_TESTS=1 vitest run --config vitest.integration.config.ts",
    "test:integration:full": "pnpm build && OBS_INTEGRATION_TESTS=1 tsx scripts/integration_test_full.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src test && jscpd src",
    "lint:fix": "eslint src test --fix",
    "check-format": "eslint src test --rule '@effect/dprint: error'",
    "format": "eslint src test --fix --rule '@effect/dprint: error'",
    "circular": "madge --extensions ts --circular src",
    "gitleaks": "gitleaks detect --redact --verbose",
    "verify-version": "node scripts/verify-version.mjs",
    "verify-registry-metadata": "node scripts/sync-registry-metadata.mjs --check",
    "sync-registry-metadata": "node scripts/sync-registry-metadata.mjs",
    "audit-protocol-parity": "tsx scripts/audit-protocol-parity.ts",
    "verify-protocol-parity": "tsx scripts/audit-protocol-parity.ts --check",
    "update-readme": "tsx scripts/update-readme-tools.ts",
    "verify-readme": "tsx scripts/update-readme-tools.ts --check",
    "package-smoke": "pnpm build && pnpm verify-version && rm -rf .package-smoke && mkdir -p .package-smoke && npm_config_ignore_scripts=true pnpm pack --pack-destination .package-smoke && tsx scripts/package-smoke.ts .package-smoke/*.tgz",
    "local-release": "pnpm dlx @changesets/cli@2.30.0 version && pnpm sync-registry-metadata && git add package.json CHANGELOG.md server.json .changeset && (git diff --cached --quiet || HUSKY=0 git commit -m \"RELEASING: Releasing 1 package(s)\") && PKG_VERSION=$(node -p \"require('./package.json').version\") && pnpm dlx esbuild@0.27.2 src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --external:ws \"--define:PKG_VERSION=\\\"$PKG_VERSION\\\"\" && pnpm verify-version && npm_config_ignore_scripts=true pnpm dlx @changesets/cli@2.30.0 publish",
    "prepack": "pnpm build && pnpm verify-version && pnpm verify-registry-metadata",
    "prepublishOnly": "pnpm check-all && pnpm verify-version",
    "check-all": "pnpm build && pnpm verify-version && pnpm typecheck && pnpm circular && pnpm verify-registry-metadata && pnpm verify-protocol-parity && pnpm verify-readme && pnpm lint && pnpm test:coverage"
  },
  "bin": {
    "obs-mcp": "dist/index.cjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "obs",
    "obs-studio",
    "obs-websocket",
    "ai-tools",
    "llm"
  ],
  "packageManager": "pnpm@10.29.3",
  "author": "dearlordylord",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "effect": "^3.19.15",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.73.1",
    "@eslint/compat": "^2.0.2",
    "@types/node": "^25.1.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "latest",
    "dotenv": "^17.4.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-functional": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "fast-check": "^4.8.0",
    "gitleaks": "^1.0.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "lint-staged": "^17.0.7",
    "madge": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "latest"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  }
}
